# Enterprise AI Document Assistant - local development settings
#
# Copy this file to .env when you need to customize host ports or local
# PostgreSQL credentials. Docker Compose uses the same development defaults
# when .env is not present.
#
# Do not reuse these values for a public or production deployment.

# Host ports
WEB_UI_HOST_PORT=3000
API_HOST_PORT=5000
AI_SERVICE_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL local development database
POSTGRES_DB=documents
POSTGRES_USER=documents
POSTGRES_PASSWORD=documents
