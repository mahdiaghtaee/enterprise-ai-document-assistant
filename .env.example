# Enterprise AI Document Assistant - local development settings
# Copy this file to .env and adjust values for your local machine.

ASPNETCORE_ENVIRONMENT=Development
DOTNET_URLS=http://+:8080

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_ai_documents
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me_for_local_dev

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=redis:6379

AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_BASE_URL=http://ai-service:8000
AI_SERVICE_TIMEOUT_SECONDS=60

DOCUMENT_STORAGE_PATH=/app/storage/documents
MAX_UPLOAD_SIZE_MB=25

RAG_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150

LOG_LEVEL=Information
